# Local development defaults. Production can point DATABASE_URL at Supabase
# Postgres while TEST_DATABASE_URL remains a separate local test database.
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"
TEST_DATABASE_URL="postgres://postgres:postgres@localhost:5433/en-escena-test"

# App origin. Canonical base URL for the app; used as a fallback when building
# auth email links.
APP_URL="https://sistema.enescena.com.ar"

# Supabase project settings. Reserved for the remaining Supabase integrations
# (Storage, Realtime or browser Data API access). Auth moved to Better Auth
# (#420); Drizzle uses DATABASE_URL directly for server-side Postgres queries.
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Better Auth (#420). BETTER_AUTH_SECRET signs sessions and the recovery-token
# cookie; generate a long random value per environment. BETTER_AUTH_URL is the
# baseURL Better Auth uses to build its endpoints and email links (defaults to
# APP_URL when unset).
BETTER_AUTH_SECRET="a-long-random-better-auth-secret"
BETTER_AUTH_URL="https://sistema.enescena.com.ar"

# Email settings. Better Auth's built-in flows and internal invitations send via
# this boundary (Brevo or Resend). Required only when NODE_ENV=production.
EMAIL_FROM="En Escena <acceso@example.com>"
EMAIL_PROVIDER="resend"
BREVO_API_KEY=""
RESEND_API_KEY=""

# Scheduled database backups to Backblaze B2. These values are used by
# scripts/backup-database-to-b2.sh and should be configured only in the
# scheduled-job environment.
B2_DATABASE_BUCKET="en-escena-db-backups"
B2_DATABASE_PREFIX="database"
B2_S3_ENDPOINT="https://s3.us-east-005.backblazeb2.com"
AWS_ACCESS_KEY_ID="your-b2-application-key-id"
AWS_SECRET_ACCESS_KEY="your-b2-application-key"
AWS_DEFAULT_REGION="us-east-005"

# Live storage. The byte store is a local Coolify volume co-located with the app
# in São Paulo; B2 is only a backup destination. STORAGE_VOLUME_DIR is the mount
# point of that volume and STORAGE_URL_SIGNING_SECRET signs the short-lived
# tokens on the /almacenamiento serving route. Encryption at rest for this
# volume is accepted debt for now (Hostinger offers no customer-facing at-rest
# encryption for VPS volumes); see the "Encryption at rest" note in
# docs/operations/backups.md before assuming the bytes on disk are encrypted.
STORAGE_VOLUME_DIR="/var/lib/en-escena/storage"
STORAGE_URL_SIGNING_SECRET="a-long-random-secret-for-signing-storage-urls"

# Scheduled storage-volume backups to Backblaze B2. scripts/backup-storage-to-b2.sh
# syncs each on-disk bucket under STORAGE_VOLUME_DIR to B2. Set BACKUP_SYNC_MODE
# to "mirror" (from "copy") to prune deleted objects during the event window.
STORAGE_BACKUP_BUCKETS="en-escena-dancer-documents,en-escena-choreography-music"
BACKUP_SYNC_MODE="copy"
B2_FILESTORE_BUCKET="en-escena-filestore-backups"
B2_FILESTORE_PREFIX="filestore"

# ARCA / facturación electrónica (#428 spike, #427 provisioning). El cert (.crt)
# y la clave privada (.key) de ARCA son PEM de texto guardados base64-encoded y
# decodificados en runtime. HOMO y PROD no son intercambiables. El emisor es la
# asociación civil (CUIT 30717611590, exenta → Factura C); el cert lo porta la
# persona física representante. Generar el base64 con: base64 -w0 archivo.crt
ARCA_CERT_HOMO_B64="base64-del-certificado-de-homologacion"
ARCA_KEY_HOMO_B64="base64-de-la-clave-privada-de-homologacion"
ARCA_CUIT="30717611590"
ARCA_PTOVTA_HOMO="1"
# Directorio donde el spike cachea el Ticket de Acceso (~12h). Opcional.
ARCA_TA_DIR="./.arca-ta"

# Performance testing settings. These are used for load testing the system with a separate database and test user.
EN_ESCENA_PERF_DB_TOKEN="custom-generated-token-for-performance-testing"
EN_ESCENA_PERF_EMAIL="custom-test-user@example.com"
EN_ESCENA_PERF_PASSWORD="custom-test-password"
EN_ESCENA_PERF_ITERATIONS=5
