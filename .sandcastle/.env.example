# Optional GitHub personal access token. If empty, Sandcastle falls back to
# `gh auth token` from the host login. The agent uses the selected token to read
# and manage GitHub Issues from inside Docker sandboxes.
# Create a fine-grained token: https://github.com/settings/personal-access-tokens/new
# Required repository permissions: Issues (Read and write) and Metadata (Read)
GH_TOKEN=

# Optional: override the host Codex ChatGPT auth file path.
# Default: ~/.codex/auth.json
CODEX_AUTH_JSON=

# Optional: Docker network used by Sandcastle containers to reach PostgreSQL.
# Default: en-escena_default, created by `docker compose up -d postgres`.
# Set to an empty value only if Sandcastle should not attach to a DB network.
SANDCASTLE_DOCKER_NETWORK=

# Optional: test database URL injected into Sandcastle containers.
# Default: postgres://postgres:postgres@postgres:5432/en-escena-test
SANDCASTLE_TEST_DATABASE_URL=
