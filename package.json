{
  "name": "en-escena",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "node --env-file=.env node_modules/@react-router/serve/bin.js ./build/server/index.js",
    "typecheck": "react-router typegen && tsc --noEmit",
    "test": "pnpm test:unit && pnpm test:db",
    "test:unit": "vitest --run",
    "test:watch": "vitest",
    "test:db": "vitest --config vitest.db.fast.config.ts --run",
    "test:db:postgres": "pnpm db:test:push && vitest --config vitest.db.config.ts --run",
    "check:file-tokens": "node --import tsx scripts/check-file-tokens.ts",
    "check:repo-styles": "node --import tsx scripts/repo-style-guardrail.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky || true",
    "db:generate": "node --env-file-if-exists=.env node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --env-file-if-exists=.env node_modules/drizzle-kit/bin.cjs migrate",
    "db:baseline": "node --env-file-if-exists=.env --import tsx scripts/baseline-migrations.ts",
    "auth:reconcile-supabase-users": "node --env-file-if-exists=.env --import tsx scripts/reconcile-supabase-users.ts",
    "backup:db:b2": "sh scripts/backup-database-to-b2.sh",
    "backup:storage:b2": "sh scripts/backup-storage-to-b2.sh",
    "restore:storage:drill": "sh scripts/restore-drill-from-b2.sh",
    "db:refresh:prod": "node scripts/refresh-local-db-from-production.mjs",
    "db:test:push": "node --import tsx tests/db/push-test-schema.ts",
    "db:studio": "node --env-file=.env node_modules/drizzle-kit/bin.cjs studio",
    "setup:secrets": "bash scripts/setup-github-secrets.sh",
    "agent:implement": "pnpm exec tsx .sandcastle/agent-implement/implement.mts",
    "agent:write-pr": "pnpm exec tsx .sandcastle/agent-write-pr/write-pr.mts",
    "agent:review": "pnpm exec tsx .sandcastle/agent-review/review.mts"
  },
  "dependencies": {
    "@arcasdk/core": "^2.0.0",
    "@aws-sdk/client-s3": "^3.1090.0",
    "@aws-sdk/s3-request-presigner": "^3.1090.0",
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@hookform/resolvers": "^5.4.0",
    "@react-router/fs-routes": "^7.11.0",
    "@react-router/node": "^7.11.0",
    "@react-router/serve": "^7.11.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/react-table": "^8.21.3",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie": "^1.0.2",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "isbot": "^5.1.27",
    "lucide-react": "^0.525.0",
    "postgres": "^3.4.7",
    "radix-ui": "^1.5.0",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.79.0",
    "react-router": "^7.11.0",
    "resend": "^6.12.4",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "^0.12.0",
    "@electric-sql/pglite": "^0.5.3",
    "@react-router/dev": "^7.11.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^20.19.11",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.4",
    "fallow": "^2.102.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "supabase": "^2.109.1",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{css,html,json,md,mdx,mjs,cjs,js,jsx,ts,tsx,yml,yaml}": "prettier --write"
  }
}
